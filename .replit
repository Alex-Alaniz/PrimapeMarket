modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm start"]
build = ["sh", "-c", "npm run build"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 35541
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 40419
externalPort = 8080
exposeLocalhost = true

[[ports]]
localPort = 44749
externalPort = 8008
exposeLocalhost = true

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 36533482

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
